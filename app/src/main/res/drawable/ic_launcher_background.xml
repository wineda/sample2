<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!--
        Branch logo background.
        ダークなグラデーション。アダプティブアイコンの背景レイヤーは
        パン・ズームされる可能性があるので、グラデは画面全体に効かせる。
    -->
    <path
        android:pathData="M0,0 L108,0 L108,108 L0,108 Z">
        <aapt:attr xmlns:aapt="http://schemas.android.com/aapt"
            name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="0"
                android:startY="0"
                android:endX="108"
                android:endY="108">
                <item android:offset="0.0" android:color="#1A1D21"/>
                <item android:offset="1.0" android:color="#2C3036"/>
            </gradient>
        </aapt:attr>
    </path>
</vector>
