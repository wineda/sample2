<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!--
        Branch logo background (light mode).
        紙のノートを思わせるクリーム色のグラデーション。
        4色のドット(紫・緑・オレンジ・青)すべてとコントラストが取れる。
    -->
    <path
        android:pathData="M0,0 L108,0 L108,108 L0,108 Z">
        <aapt:attr xmlns:aapt="http://schemas.android.com/aapt"
            name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="0"
                android:startY="0"
                android:endX="108"
                android:endY="108">
                <item android:offset="0.0" android:color="#FAFAF6"/>
                <item android:offset="1.0" android:color="#F0EEE5"/>
            </gradient>
        </aapt:attr>
    </path>
</vector>
