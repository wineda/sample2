<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!--
        Branch logo foreground (light mode).

        Android アダプティブアイコンの安全領域(中心 72x72、座標 18..90)を
        ほぼフルに使う配置。各要素は最低 4 dp のマージンを保つ。

        4ノードの配置:
          - 親(紫):              (32, 32) r=10  ← 左上、強調
          - 子1(緑):             (74, 60) r=6   ← 右、中段
          - 子2(オレンジ):        (74, 76) r=6   ← 右下
          - もう一つの親(青、α=0.7): (32, 78) r=6   ← 左下、独立
    -->

    <!-- 親→子1 の接続線 (紫の底から下、緑の左端へ) -->
    <path
        android:pathData="M 32 42 L 32 60 L 68 60"
        android:strokeColor="#1A1D21"
        android:strokeWidth="1.7"
        android:strokeLineCap="round"
        android:fillColor="#00000000"/>

    <!-- 親→子2 の接続線 (中継点から斜めにオレンジの左端へ) -->
    <path
        android:pathData="M 32 60 L 68 76"
        android:strokeColor="#1A1D21"
        android:strokeWidth="1.7"
        android:strokeLineCap="round"
        android:fillColor="#00000000"/>

    <!-- 親ノード(紫) cx=32, cy=32, r=10 -->
    <path
        android:fillColor="#9C27B0"
        android:pathData="M32,22 C37.52,22 42,26.48 42,32 C42,37.52 37.52,42 32,42 C26.48,42 22,37.52 22,32 C22,26.48 26.48,22 32,22 Z"/>

    <!-- 子ノード(緑) cx=74, cy=60, r=6 -->
    <path
        android:fillColor="#43A047"
        android:pathData="M74,54 C77.31,54 80,56.69 80,60 C80,63.31 77.31,66 74,66 C70.69,66 68,63.31 68,60 C68,56.69 70.69,54 74,54 Z"/>

    <!-- 子ノード(オレンジ) cx=74, cy=76, r=6 -->
    <path
        android:fillColor="#FB8C00"
        android:pathData="M74,70 C77.31,70 80,72.69 80,76 C80,79.31 77.31,82 74,82 C70.69,82 68,79.31 68,76 C68,72.69 70.69,70 74,70 Z"/>

    <!-- もう一つの親(青、半透明) cx=32, cy=78, r=6 -->
    <path
        android:fillColor="#1976D2"
        android:fillAlpha="0.7"
        android:pathData="M32,72 C35.31,72 38,74.69 38,78 C38,81.31 35.31,84 32,84 C28.69,84 26,81.31 26,78 C26,74.69 28.69,72 32,72 Z"/>
